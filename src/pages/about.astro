---
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/CTASection.astro';
---

<BaseLayout title="About Us" description="Learn about Zenzeni Africa Safari, a Kenya travel company planning premium safaris, beach holidays, corporate excursions, and custom trips.">
  <section class="bg-white py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div>
        <p class="eyebrow">About Zenzeni</p>
        <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Kenya journeys shaped with care, clarity, and local insight.</h1>
        <p class="mt-6 leading-8 text-stone-700">Zenzeni Africa Safari is a travel planning company built for guests who want safari, coast, culture, and corporate travel handled by people who know the routes, seasons, lodges, and details that make a trip work.</p>
      </div>
      <img class="h-[520px] w-full rounded-2xl object-cover shadow-soft" src="https://images.unsplash.com/photo-1516426122078-c23e76319801?auto=format&fit=crop&w=1200&q=80" alt="Safari vehicle in Kenya" />
    </div>
  </section>
  <section class="py-20">
    <div class="container-page grid gap-6 md:grid-cols-3">
      {[
        ['Our promise', 'Clear quotes, responsive planning, and practical guidance before you travel.'],
        ['Our style', 'Premium but grounded: elegant lodges, strong logistics, and experiences that feel authentic.'],
        ['Our reach', 'Wildlife parks, beaches, hikes, waterfalls, hotels, transfers, and corporate excursions across Kenya.']
      ].map(([title, text]) => (
        <div class="rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60">
          <h2 class="font-display text-2xl font-bold text-savanna-bark">{title}</h2>
          <p class="mt-3 text-sm leading-7 text-stone-600">{text}</p>
        </div>
      ))}
    </div>
  </section>
  <CTASection />
</BaseLayout>
