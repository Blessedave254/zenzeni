---
import BaseLayout from '@layouts/BaseLayout.astro';
import BookingForm from '@components/BookingForm.astro';
import ItineraryTimeline from '@components/ItineraryTimeline.astro';
import PaymentOptions from '@components/PaymentOptions.astro';
import CTASection from '@components/CTASection.astro';
import { packages } from '@data/packages';
import { site } from '@data/site';

export function getStaticPaths() {
  return packages.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: item.title,
  description: item.shortDescription,
  image: item.image,
  touristType: ['Safari travellers', 'Families', 'Couples', 'Corporate groups'],
  itinerary: item.itinerary.map((day) => `${day.day}: ${day.title}`),
  offers: {
    '@type': 'Offer',
    price: item.price,
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    url: `${site.url}/packages/${item.slug}`
  }
};
---

<BaseLayout title={item.title} description={item.shortDescription} image={item.image} schema={schema}>
  <section class="bg-white py-12">
    <div class="container-page grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="eyebrow">{item.location} • {item.durationDays} {item.durationDays === 1 ? 'day' : 'days'}</p>
        <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">{item.title}</h1>
        <p class="mt-5 text-lg leading-8 text-stone-700">{item.fullDescription}</p>
        <div class="mt-7 flex flex-wrap items-center gap-4">
          <span class="rounded-full bg-savanna-cream px-5 py-3 font-bold text-savanna-bark">From ${item.price}</span>
          <a class="btn-primary" href="#booking">Book this package</a>
        </div>
      </div>
      <img class="h-[480px] w-full rounded-2xl object-cover shadow-soft" src={item.image} alt={item.title} />
    </div>
  </section>

  <section class="py-16">
    <div class="container-page grid gap-4 md:grid-cols-3">
      {item.gallery.map((image) => <img class="h-64 w-full rounded-2xl object-cover shadow-soft" src={image} alt={`${item.title} gallery`} loading="lazy" />)}
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-page grid gap-10 lg:grid-cols-2">
      <div>
        <p class="eyebrow">Itinerary</p>
        <h2 class="section-title mt-3">{item.durationDays === 1 ? 'Simple day plan' : 'Day-by-day journey'}</h2>
        <div class="mt-8">
          <ItineraryTimeline itinerary={item.itinerary} durationDays={item.durationDays} />
        </div>
      </div>
      <div class="grid gap-6">
        <div class="rounded-2xl bg-savanna-cream p-6">
          <h2 class="font-display text-2xl font-bold text-savanna-bark">Included</h2>
          <ul class="mt-4 grid gap-2 text-sm text-stone-700">
            {item.included.map((entry) => <li>• {entry}</li>)}
          </ul>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60">
          <h2 class="font-display text-2xl font-bold text-savanna-bark">Excluded</h2>
          <ul class="mt-4 grid gap-2 text-sm text-stone-700">
            {item.excluded.map((entry) => <li>• {entry}</li>)}
          </ul>
        </div>
        <div class="rounded-2xl bg-savanna-sky p-6">
          <h2 class="font-display text-2xl font-bold text-savanna-bark">Activities</h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {item.activities.map((entry) => <span class="rounded-full bg-white px-4 py-2 text-sm font-bold text-savanna-bark">{entry}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="booking" class="py-16">
    <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Booking form</p>
        <h2 class="section-title mt-3">Reserve this package</h2>
        <p class="mt-4 text-sm leading-7 text-stone-600">Submit your preferred date and group details. Our team will confirm availability and send payment instructions.</p>
      </div>
      <BookingForm selectedPackage={item.slug} />
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-page">
      <p class="eyebrow">Payment options</p>
      <h2 class="section-title mt-3">Prepared for M-Pesa and card payments</h2>
      <div class="mt-8">
        <PaymentOptions amount={item.price} bookingReference={`ZAS-${item.slug.toUpperCase()}`} />
      </div>
    </div>
  </section>
  <CTASection />
</BaseLayout>
