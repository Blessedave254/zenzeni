---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Terms and Conditions" description="Read the booking terms and conditions for Zenzeni Africa Safari travel services.">
  <section class="py-20">
    <div class="container-page max-w-4xl">
      <p class="eyebrow">Terms</p>
      <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Terms and Conditions</h1>
      <div class="mt-8 space-y-6 text-sm leading-7 text-stone-700">
        <p>Bookings are confirmed after availability is verified and the required deposit or full payment is received. Quotes may vary based on season, lodge availability, park fees, exchange rates, and group size.</p>
        <p>Cancellation, refund, and amendment terms depend on supplier policies and the confirmed itinerary. Guests are responsible for valid travel documents, insurance, health requirements, and accurate booking information.</p>
        <p>Zenzeni Africa Safari acts as a travel planner and coordinator with hotels, transport providers, guides, parks, and payment partners. Final supplier terms will be shared before payment where applicable.</p>
      </div>
    </div>
  </section>
</BaseLayout>
