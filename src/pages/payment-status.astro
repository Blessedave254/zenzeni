---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Payment Status" description="Check the payment status for a Zenzeni Africa Safari booking.">
  <section class="py-24">
    <div class="container-page max-w-3xl">
      <p class="eyebrow">Payment status</p>
      <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Payment status placeholder.</h1>
      <p class="mt-5 leading-8 text-stone-700">When payment providers are connected, this page can show pending, successful, failed, or cancelled transaction states using the booking reference.</p>
      <div class="mt-8 rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60">
        <p class="font-bold text-savanna-bark">Reference: ZAS-DEMO-001</p>
        <p class="mt-2 text-sm text-stone-600">Status: Awaiting provider integration</p>
      </div>
    </div>
  </section>
</BaseLayout>
