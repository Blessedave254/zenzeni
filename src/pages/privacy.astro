---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="Read how Zenzeni Africa Safari handles booking enquiries, contact details, travel preferences, and payment-related information.">
  <section class="py-20">
    <div class="container-page max-w-4xl">
      <p class="eyebrow">Privacy</p>
      <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Privacy Policy</h1>
      <div class="mt-8 space-y-6 text-sm leading-7 text-stone-700">
        <p>We collect information needed to respond to enquiries, prepare quotes, manage bookings, and coordinate travel services. This may include contact details, travel dates, group information, preferences, and special requests.</p>
        <p>Payment details should be processed through secure payment providers once integrated. We do not intend to store full card details in this frontend application.</p>
        <p>We may share necessary booking details with lodges, transport providers, guides, payment processors, and travel partners involved in delivering your trip.</p>
      </div>
    </div>
  </section>
</BaseLayout>
