---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Booking Confirmation" description="Your Zenzeni Africa Safari booking request has been received.">
  <section class="py-24">
    <div class="container-page max-w-3xl text-center">
      <p class="eyebrow">Booking received</p>
      <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Thank you. Your request is with our travel team.</h1>
      <p class="mt-5 leading-8 text-stone-700">We will confirm availability, final itinerary details, and the correct payment link or M-Pesa prompt instructions.</p>
      <a class="btn-primary mt-8" href="/payment">Continue to payment</a>
    </div>
  </section>
</BaseLayout>
