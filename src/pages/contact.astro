---
import BaseLayout from '@layouts/BaseLayout.astro';
import { site } from '@data/site';
---

<BaseLayout title="Contact Zenzeni Africa Safari" description="Contact Zenzeni Africa Safari for Kenya safari bookings, beach holidays, corporate excursions, airport transfers, and custom travel planning.">
  <section class="py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Contact us</p>
        <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Let’s shape your Kenya journey.</h1>
        <div class="mt-8 grid gap-4 text-sm text-stone-700">
          <p><strong>Phone:</strong> {site.phone}</p>
          <p><strong>Email:</strong> {site.email}</p>
          <p><strong>Office:</strong> {site.address}</p>
        </div>
      </div>
      <form class="grid gap-5 rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60" method="post" action="/api/contact">
        <div class="grid gap-5 md:grid-cols-2">
          <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3" name="name" placeholder="Full name" required />
          <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3" type="email" name="email" placeholder="Email address" required />
        </div>
        <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3" name="subject" placeholder="Subject" required />
        <textarea class="min-h-40 rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3" name="message" placeholder="Tell us what you want to plan" required></textarea>
        <button class="btn-primary w-full sm:w-auto" type="submit">Send message</button>
      </form>
    </div>
  </section>
</BaseLayout>
