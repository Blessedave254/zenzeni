---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSlider from '@components/HeroSlider.astro';
import PackageCard from '@components/PackageCard.astro';
import DestinationCard from '@components/DestinationCard.astro';
import ActivityCard from '@components/ActivityCard.astro';
import BlogCard from '@components/BlogCard.astro';
import TestimonialCard from '@components/TestimonialCard.astro';
import CTASection from '@components/CTASection.astro';
import { packages } from '@data/packages';
import { destinations } from '@data/destinations';
import { activities } from '@data/activities';
import { blogs } from '@data/blogs';
import { testimonials } from '@data/testimonials';
---

<BaseLayout title="Kenya Safari Tours, Beach Holidays and Travel Packages" description="Book premium Kenya safaris, beach holidays, corporate excursions, hiking trips, and custom travel packages with Zenzeni Africa Safari.">
  <HeroSlider />

  <section class="bg-white py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="eyebrow">Your trusted Kenya travel partner</p>
        <h2 class="section-title mt-3">Karibu to Zenzeni Africa Safaris</h2>
      </div>
      <div class="space-y-5 text-base leading-8 text-stone-700">
        <p>
          Step away from the everyday and discover Kenya through journeys shaped around you. From the wildlife-rich plains of the Maasai Mara and Amboseli to Rift Valley lakes, mountain trails, waterfalls, and the warm Indian Ocean coast, we bring every part of your holiday together with care.
        </p>
        <p>
          We plan private safaris, beach holidays, honeymoons, family adventures, corporate retreats, day trips, transfers, and fully custom itineraries. Whether it is your first safari or a return to a place you love, our local team helps you travel with confidence from the first conversation to the final drop-off.
        </p>
        <div class="flex flex-wrap gap-4 pt-2">
          <a href="/about" class="btn-secondary">Meet Zenzeni</a>
          <a href="/booking" class="btn-primary">Plan your journey</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Featured destinations</p>
          <h2 class="section-title mt-3">Kenya places worth slowing down for</h2>
        </div>
        <a href="/destinations" class="btn-secondary">View all destinations</a>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {destinations.slice(0, 4).map((item) => <DestinationCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Popular packages</p>
          <h2 class="section-title mt-3">Safari and coast trips ready to book</h2>
        </div>
        <a href="/packages" class="btn-primary">Browse packages</a>
      </div>
      <div class="mt-10 grid gap-7 lg:grid-cols-3">
        {packages.slice(0, 3).map((item) => <PackageCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page">
      <p class="eyebrow">Activities</p>
      <h2 class="section-title mt-3">Travel styles for every kind of guest</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {activities.slice(0, 8).map((item) => <ActivityCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="bg-savanna-sky py-20">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow">Why choose us</p>
        <h2 class="section-title mt-3">Thoughtful journeys, backed by people who know Kenya</h2>
        <p class="mt-5 leading-8 text-stone-700">We combine practical local knowledge with attentive planning, dependable partners, and honest guidance so every guest feels looked after before, during, and after the journey.</p>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'We know the way', subtitle: 'Local expertise', text: 'Routes, seasons, parks, stays, and transfers are planned with on-the-ground understanding.' },
          { title: 'We listen first', subtitle: 'Personal planning', text: 'Your pace, interests, group, and budget guide the itinerary instead of a one-size-fits-all template.' },
          { title: 'We stay close', subtitle: 'Reliable support', text: 'Clear communication and practical assistance keep your trip running smoothly from enquiry to return.' },
          { title: 'We value your trust', subtitle: 'Fair, clear choices', text: 'Straightforward inclusions, carefully selected partners, and flexible options help you book confidently.' }
        ].map((item) => (
          <div class="rounded-lg border border-white/70 bg-white p-6 shadow-soft">
            <p class="eyebrow">{item.subtitle}</p>
            <h3 class="mt-3 font-display text-2xl font-bold text-savanna-bark">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-stone-600">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-page">
      <p class="eyebrow">Guest stories</p>
      <h2 class="section-title mt-3">Travel that feels carefully handled</h2>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {testimonials.map((item) => <TestimonialCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="container-page">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Safari notes</p>
          <h2 class="section-title mt-3">Planning guides from our team</h2>
        </div>
        <a href="/blog" class="btn-secondary">Read blog</a>
      </div>
      <div class="mt-10 grid gap-7 lg:grid-cols-3">
        {blogs.map((item) => <BlogCard item={item} />)}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
