---
import BaseLayout from '@layouts/BaseLayout.astro';
import CTASection from '@components/CTASection.astro';
import { destinations } from '@data/destinations';

export function getStaticPaths() {
  return destinations.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
---

<BaseLayout title={`${item.title} Travel Guide`} description={item.summary} image={item.image}>
  <section class="bg-white py-16">
    <div class="container-page grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
      <div>
        <p class="eyebrow">{item.region}</p>
        <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">{item.title}</h1>
        <p class="mt-5 text-lg leading-8 text-stone-700">{item.description}</p>
        <a class="btn-primary mt-8" href="/booking">Plan this destination</a>
      </div>
      <img class="h-[500px] w-full rounded-2xl object-cover shadow-soft" src={item.image} alt={item.title} />
    </div>
  </section>
  <section class="py-16">
    <div class="container-page grid gap-8 md:grid-cols-2">
      <div class="rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60">
        <h2 class="font-display text-2xl font-bold text-savanna-bark">Highlights</h2>
        <ul class="mt-4 grid gap-3 text-sm text-stone-700">
          {item.highlights.map((entry) => <li>• {entry}</li>)}
        </ul>
      </div>
      <div class="rounded-2xl bg-savanna-sky p-6">
        <h2 class="font-display text-2xl font-bold text-savanna-bark">Best for</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {item.bestFor.map((entry) => <span class="rounded-full bg-white px-4 py-2 text-sm font-bold text-savanna-bark">{entry}</span>)}
        </div>
      </div>
    </div>
  </section>
  <CTASection title={`Plan a ${item.title} trip`} />
</BaseLayout>
