---
import BaseLayout from '@layouts/BaseLayout.astro';
import DestinationCard from '@components/DestinationCard.astro';
import CTASection from '@components/CTASection.astro';
import { destinations } from '@data/destinations';
---

<BaseLayout title="Kenya Safari and Beach Destinations" description="Explore Kenya destinations including Maasai Mara, Amboseli, Tsavo, Lake Nakuru, Diani, Watamu, Malindi, Naivasha, Mount Kenya, and waterfalls.">
  <section class="py-20">
    <div class="container-page">
      <p class="eyebrow">Destinations</p>
      <h1 class="mt-3 font-display text-5xl font-bold text-savanna-bark">Safari parks, beaches, forests, mountains, and waterfalls.</h1>
      <div class="mt-10 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {destinations.map((item) => <DestinationCard item={item} />)}
      </div>
    </div>
  </section>
  <CTASection />
</BaseLayout>
