---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import FloatingWhatsApp from '@components/FloatingWhatsApp.astro';
import SafariAssistant from '@components/SafariAssistant.astro';
import SEO from '@components/SEO.astro';
import { site } from '@data/site';
import { getLocaleFromPathname, stripLocaleFromPathname, supportedLocales } from '@lib/i18n';
import '../styles.css';

type Props = {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
};

const travelAgencySchema = {
  '@context': 'https://schema.org',
  '@type': 'TravelAgency',
  name: site.name,
  url: site.url,
  telephone: site.phone,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Nairobi',
    addressCountry: 'KE'
  },
  areaServed: 'Kenya',
  description: site.description,
  sameAs: Object.values(site.social)
};

const props = Astro.props;
const schema = props.schema
  ? [travelAgencySchema, ...(Array.isArray(props.schema) ? props.schema : [props.schema])]
  : [travelAgencySchema];
const locale = getLocaleFromPathname(Astro.url.pathname);
const basePath = stripLocaleFromPathname(Astro.url.pathname);
const alternates =
  basePath === '/'
    ? [
        { hrefLang: 'x-default', href: '/' },
        ...supportedLocales.map((item: (typeof supportedLocales)[number]) => ({
          hrefLang: item,
          href: item === 'en' ? '/' : `/${item}/`
        }))
      ]
    : [];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,500;0,600;0,700;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <SEO {...props} schema={schema} alternates={alternates} />
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <SafariAssistant locale={locale} />
    <FloatingWhatsApp />
    <Footer locale={locale} />
  </body>
</html>
