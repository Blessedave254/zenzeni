---
import HeroSlider from '@components/HeroSlider.astro';
import PackageCard from '@components/PackageCard.astro';
import DestinationCard from '@components/DestinationCard.astro';
import ActivityCard from '@components/ActivityCard.astro';
import BlogCard from '@components/BlogCard.astro';
import TestimonialCard from '@components/TestimonialCard.astro';
import CTASection from '@components/CTASection.astro';
import { activities } from '@data/activities';
import { blogs } from '@data/blogs';
import { destinations } from '@data/destinations';
import { packages } from '@data/packages';
import { testimonials } from '@data/testimonials';
import { type Locale, homeCopy, ui } from '@lib/i18n';

const { locale = 'en' } = Astro.props as { locale?: Locale };
const copy = homeCopy[locale];
type WhyCard = { title: string; subtitle: string; text: string };

const whyChooseCards: Record<Locale, WhyCard[]> = {
  en: [
    { title: 'We know the way', subtitle: 'Local expertise', text: 'Routes, seasons, parks, stays, and transfers are planned with on-the-ground understanding.' },
    { title: 'We listen first', subtitle: 'Personal planning', text: 'Your pace, interests, group, and budget guide the itinerary instead of a one-size-fits-all template.' },
    { title: 'We stay close', subtitle: 'Reliable support', text: 'Clear communication and practical assistance keep your trip running smoothly from enquiry to return.' },
    { title: 'We value your trust', subtitle: 'Fair, clear choices', text: 'Straightforward inclusions, carefully selected partners, and flexible options help you book confidently.' }
  ],
  sw: [
    { title: 'Tunajua njia', subtitle: 'Uzoefu wa ndani', text: 'Njia, misimu, mbuga, malazi, na uhamisho hupangwa kwa uelewa wa karibu wa maeneo.' },
    { title: 'Kusikiliza kwanza', subtitle: 'Mipango binafsi', text: 'Kasi yako, maslahi, kundi, na bajeti ndivyo vinavyoongoza ratiba, si mpangilio wa aina moja.' },
    { title: 'Tunasalia karibu', subtitle: 'Msaada wa kuaminika', text: 'Mawasiliano ya wazi na msaada wa vitendo huifanya safari yako iende vizuri kuanzia kuuliza hadi kurudi.' },
    { title: 'Tunathamini uaminifu wako', subtitle: 'Chaguo wazi na la haki', text: 'Vipengele vilivyo wazi, washirika walioteuliwa kwa uangalifu, na chaguo rahisi hukusaidia kuweka nafasi kwa uhakika.' }
  ],
  de: [
    { title: 'Wir kennen den Weg', subtitle: 'Lokale Expertise', text: 'Routen, Jahreszeiten, Parks, Unterkünfte und Transfers werden mit Vor-Ort-Wissen geplant.' },
    { title: 'Wir hören zuerst zu', subtitle: 'Persönliche Planung', text: 'Tempo, Interessen, Gruppe und Budget bestimmen die Route statt einer Standardvorlage.' },
    { title: 'Wir bleiben nah dran', subtitle: 'Verlässliche Unterstützung', text: 'Klare Kommunikation und praktische Hilfe sorgen für einen reibungslosen Ablauf.' },
    { title: 'Wir schätzen Ihr Vertrauen', subtitle: 'Faire, klare Wahl', text: 'Transparente Leistungen, sorgfältig gewählte Partner und flexible Optionen geben Sicherheit beim Buchen.' }
  ],
  fr: [
    { title: 'Nous connaissons la route', subtitle: 'Expertise locale', text: 'Les itinéraires, saisons, parcs, hébergements et transferts sont planifiés avec une vraie connaissance du terrain.' },
    { title: 'Nous écoutons d’abord', subtitle: 'Planification personnelle', text: 'Votre rythme, vos envies, votre groupe et votre budget guident l’itinéraire.' },
    { title: 'Nous restons proches', subtitle: 'Assistance fiable', text: 'Une communication claire et un soutien pratique assurent un voyage fluide du début à la fin.' },
    { title: 'Nous respectons votre confiance', subtitle: 'Choix clairs et justes', text: 'Des prestations transparentes, des partenaires choisis avec soin et des options flexibles permettent de réserver en confiance.' }
  ]
} as const;
---

<HeroSlider locale={locale} />

<section class="bg-white py-16 sm:py-24">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-16">
      <div class="max-w-2xl">
        <div class="flex items-center gap-4">
          <span class="h-px w-10 bg-savanna-gold/70" aria-hidden="true"></span>
          <p class="font-display text-base font-semibold italic text-savanna-clay sm:text-lg">{copy.introEyebrow}</p>
        </div>
        <h2 class="mt-5 font-display text-4xl font-bold leading-tight text-savanna-bark sm:text-5xl">{copy.introTitle}</h2>
        <p class="mt-6 text-base leading-8 text-stone-600 sm:text-lg sm:leading-9">{copy.introBody}</p>
        <p class="mt-7 font-display text-lg font-semibold italic leading-8 text-savanna-bark sm:text-xl">{copy.introClosing}</p>
        <a href="/about" class="btn-primary mt-8">{ui[locale].actions.discoverStory}</a>
      </div>
      <div class="relative aspect-[4/3] overflow-hidden rounded-lg bg-savanna-sand shadow-soft lg:aspect-[4/5]">
        <video
          class="h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="https://images.unsplash.com/photo-1659848005803-cc45d61fc888?auto=format&fit=crop&w=1200&q=82"
          aria-label="Cinematic safari footage from Kenya"
        >
          <source src="/zenzeni-Video-Promo.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-tr from-savanna-bark/25 via-transparent to-savanna-gold/10"></div>
        <div class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-savanna-bark/10"></div>
      </div>
    </div>
  </div>
</section>

<section class="py-20">
  <div class="container-page">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">{copy.featuredDestinations}</p>
        <h2 class="section-title mt-3">{copy.featuredDestinationsTitle}</h2>
      </div>
      <a href="/destinations" class="btn-secondary">{ui[locale].actions.viewAllDestinations}</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {destinations.slice(0, 4).map((item) => <DestinationCard item={item} />)}
    </div>
  </div>
</section>

<section class="bg-white py-20">
  <div class="container-page">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">{copy.popularPackages}</p>
        <h2 class="section-title mt-3">{copy.popularPackagesTitle}</h2>
      </div>
      <a href="/packages" class="btn-primary">{ui[locale].actions.browsePackages}</a>
    </div>
    <div class="mt-10 grid gap-7 lg:grid-cols-3">
      {packages.slice(0, 3).map((item) => <PackageCard item={item} locale={locale} />)}
    </div>
  </div>
</section>

<section class="py-20">
  <div class="container-page">
    <p class="eyebrow">{copy.activitiesEyebrow}</p>
    <h2 class="section-title mt-3">{copy.activitiesTitle}</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {activities.slice(0, 8).map((item) => <ActivityCard item={item} />)}
    </div>
  </div>
</section>

<section class="bg-savanna-sky py-20">
  <div class="container-page">
    <div class="max-w-3xl">
      <p class="eyebrow">{copy.whyChooseEyebrow}</p>
      <h2 class="section-title mt-3">{copy.whyChooseTitle}</h2>
      <p class="mt-5 leading-8 text-stone-700">{copy.whyChooseBody}</p>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {whyChooseCards[locale].map((item: WhyCard) => (
        <div class="rounded-lg border border-white/70 bg-white p-6 shadow-soft">
          <p class="eyebrow">{item.subtitle}</p>
          <h3 class="mt-3 font-display text-2xl font-bold text-savanna-bark">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-stone-600">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-20">
  <div class="container-page">
    <p class="eyebrow">{copy.guestStoriesEyebrow}</p>
    <h2 class="section-title mt-3">{copy.guestStoriesTitle}</h2>
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {testimonials.map((item) => <TestimonialCard item={item} />)}
    </div>
  </div>
</section>

<section class="bg-white py-20">
  <div class="container-page">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">{copy.safariNotesEyebrow}</p>
        <h2 class="section-title mt-3">{copy.safariNotesTitle}</h2>
      </div>
      <a href="/blog" class="btn-secondary">{ui[locale].actions.readBlog}</a>
    </div>
    <div class="mt-10 grid gap-7 lg:grid-cols-3">
      {blogs.map((item) => <BlogCard item={item} locale={locale} />)}
    </div>
  </div>
</section>

<CTASection locale={locale} />
