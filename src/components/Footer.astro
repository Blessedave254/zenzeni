---
import { packages } from '@data/packages';
import { navigation, site } from '@data/site';
import { type Locale, ui } from '@lib/i18n';

const footerPackages = packages.slice(0, 5);
const { locale = 'en' } = Astro.props as { locale?: Locale };
const copy = ui[locale];
---

<footer class="bg-savanna-bark text-white">
  <div class="container-page grid gap-10 py-14 md:grid-cols-2 xl:grid-cols-[1.25fr_0.55fr_0.85fr_0.75fr]">
    <div>
      <div class="flex items-center gap-4">
        <span class="grid h-20 w-20 place-items-center rounded-full bg-savanna-cream p-2">
          <img class="h-full w-full object-contain" src="/images/logo.png" alt="Zenzeni Africa Safaris logo" loading="lazy" />
        </span>
        <p class="font-display text-3xl font-bold">Zenzeni Africa Safaris</p>
      </div>
      <p class="mt-4 max-w-xl text-sm leading-7 text-white/75">{site.description}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-secondary border-white/25 bg-white/10 text-white hover:bg-white hover:text-savanna-bark" href="/booking">{copy.footer.planTrip}</a>
        <a class="btn-secondary border-white/25 bg-white/10 text-white hover:bg-white hover:text-savanna-bark" href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </div>
    <div>
      <p class="text-sm font-black uppercase tracking-[0.2em] text-savanna-gold">{copy.footer.explore}</p>
      <div class="mt-5 grid gap-3">
        {navigation.map((item) => (
          <a class="text-sm text-white/75 hover:text-white" href={item.href}>
            {copy.nav[item.key as keyof typeof copy.nav]}
          </a>
        ))}
      </div>
    </div>
    <div>
      <p class="text-sm font-black uppercase tracking-[0.2em] text-savanna-gold">{copy.footer.packages}</p>
      <div class="mt-5 grid gap-3">
        {footerPackages.map((item) => <a class="text-sm text-white/75 hover:text-white" href={`/packages/${item.slug}`}>{item.title}</a>)}
        <a class="text-sm font-bold text-savanna-gold hover:text-white" href="/packages">{copy.actions.viewAllPackages}</a>
      </div>
    </div>
    <div>
      <p class="text-sm font-black uppercase tracking-[0.2em] text-savanna-gold">{copy.footer.contact}</p>
      <div class="mt-5 grid gap-3 text-sm text-white/75">
        <a href={`tel:${site.phone}`}>{site.phone}</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span>{site.address}</span>
      </div>
      <div class="mt-6">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-white/55">{locale === 'sw' ? 'Fuata' : locale === 'de' ? 'Folgen' : locale === 'fr' ? 'Suivez' : 'Follow'}</p>
        <div class="mt-3 flex items-center gap-3">
          <a class="grid h-10 w-10 place-items-center rounded-full border border-white/15 bg-white/10 text-white transition hover:bg-white hover:text-savanna-bark" href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" title="Facebook">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.3-1.6 1.7-1.6H17V4.5c-.6-.1-1.8-.2-3-.2-2.9 0-4.9 1.8-4.9 5V11H6.4V14h2.7v8h4.4Z" />
            </svg>
          </a>
          <a class="grid h-10 w-10 place-items-center rounded-full border border-white/15 bg-white/10 text-white transition hover:bg-white hover:text-savanna-bark" href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="4" y="4" width="16" height="16" rx="4" />
              <path d="M9 12a3 3 0 1 0 6 0 3 3 0 0 0-6 0Z" />
              <path d="M16.5 7.5h.01" />
            </svg>
          </a>
          <a class="grid h-10 w-10 place-items-center rounded-full border border-white/15 bg-white/10 text-white transition hover:bg-white hover:text-savanna-bark" href={site.social.x} target="_blank" rel="noopener noreferrer" aria-label="X" title="X">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.9 2H22l-6.8 7.8L23.2 22h-6.7l-5.2-6.7L5.4 22H2.3l7.3-8.4L.8 2h6.9l4.7 6L18.9 2Zm-1.2 18h1.7L6.8 3.9H4.9L17.7 20Z" />
            </svg>
          </a>
          <a class="grid h-10 w-10 place-items-center rounded-full border border-white/15 bg-white/10 text-white transition hover:bg-white hover:text-savanna-bark" href={site.social.tripadvisor} target="_blank" rel="noopener noreferrer" aria-label="Tripadvisor" title="Tripadvisor">
            <svg class="h-5 w-5" viewBox="0 0 48 32" fill="none" aria-hidden="true">
              <circle cx="14" cy="16" r="9" stroke="currentColor" stroke-width="4" />
              <circle cx="34" cy="16" r="9" stroke="currentColor" stroke-width="4" />
              <circle cx="14" cy="16" r="3" fill="currentColor" />
              <circle cx="34" cy="16" r="3" fill="currentColor" />
              <path d="M23 16h2" stroke="currentColor" stroke-width="4" stroke-linecap="round" />
              <path d="M10 7.5c2.6-1.6 5.6-2.5 8.8-2.5 2.2 0 4.3.4 6.2 1.2" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
              <path d="M38 7.5c-2.6-1.6-5.6-2.5-8.8-2.5-2.2 0-4.3.4-6.2 1.2" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10 py-5">
    <div class="container-page flex flex-col gap-3 text-xs text-white/60 sm:flex-row sm:items-center sm:justify-between">
      <p>© {new Date().getFullYear()} Zenzeni Africa Safaris. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/terms">{copy.footer.terms}</a>
        <a href="/privacy">{copy.footer.privacy}</a>
      </div>
    </div>
  </div>
</footer>
