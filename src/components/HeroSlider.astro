---
const slides = [
  {
    image: 'https://images.unsplash.com/photo-1516426122078-c23e76319801?auto=format&fit=crop&w=1800&q=80',
    label: 'Maasai Mara wildlife safaris'
  },
  {
    image: 'https://images.unsplash.com/photo-1534177616072-ef7dc120449d?auto=format&fit=crop&w=1800&q=80',
    label: 'Amboseli elephant journeys'
  },
  {
    image: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1800&q=80',
    label: 'Kenya coast beach holidays'
  }
];
---

<section class="relative min-h-[calc(100vh-5rem)] overflow-hidden bg-savanna-bark text-white">
  <div class="absolute inset-0">
    {slides.map((slide, index) => (
      <img
        class={`absolute inset-0 h-full w-full object-cover opacity-0 motion-safe:animate-[heroFade_18s_infinite] ${index === 0 ? 'opacity-100' : ''}`}
        style={`animation-delay:${index * 6}s`}
        src={slide.image}
        alt={slide.label}
        loading={index === 0 ? 'eager' : 'lazy'}
      />
    ))}
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/45 to-black/15"></div>
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-savanna-cream to-transparent"></div>
  </div>
  <div class="container-page relative flex min-h-[calc(100vh-5rem)] items-center py-20">
    <div class="max-w-3xl">
      <p class="eyebrow text-savanna-gold">Private Kenya safari and coast holidays</p>
      <h1 class="mt-5 font-display text-5xl font-bold leading-tight text-white sm:text-6xl lg:text-7xl">
        Explore Kenya with trusted local safari planners.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/85">
        Premium wildlife safaris, beach escapes, corporate excursions, and custom itineraries across Kenya’s most memorable destinations.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/packages" class="btn-primary bg-savanna-gold text-savanna-bark hover:bg-white">View packages</a>
        <a href="/booking" class="btn-secondary border-white/40 bg-white/10 text-white hover:bg-white hover:text-savanna-bark">Start booking</a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes heroFade {
    0%, 28% { opacity: 1; transform: scale(1); }
    34%, 94% { opacity: 0; transform: scale(1.04); }
    100% { opacity: 1; transform: scale(1); }
  }
</style>
