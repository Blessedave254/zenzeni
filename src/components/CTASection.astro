---
const { title = 'Ready to plan your Kenya escape?', text = 'Tell us your dates, budget, and travel style. We will shape a safari or beach itinerary around you.' } = Astro.props;
---

<section class="bg-savanna-leaf py-16 text-white">
  <div class="container-page flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
    <div class="max-w-2xl">
      <p class="eyebrow text-savanna-gold">Custom travel planning</p>
      <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">{title}</h2>
      <p class="mt-4 text-sm leading-7 text-white/75">{text}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/booking" class="btn-primary bg-savanna-gold text-savanna-bark hover:bg-white">Book a trip</a>
      <a href="/contact" class="btn-secondary border-white/30 bg-white/10 text-white hover:bg-white hover:text-savanna-bark">Contact us</a>
    </div>
  </div>
</section>
