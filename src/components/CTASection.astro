---
import { type Locale, homeCopy, ui } from '@lib/i18n';

const { locale = 'en' } = Astro.props as { locale?: Locale };
const copy = homeCopy[locale];
const shell = ui[locale];
---

<section class="bg-savanna-leaf py-16 text-white">
  <div class="container-page flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
    <div class="max-w-2xl">
      <p class="eyebrow text-savanna-gold">{copy.ctaEyebrow}</p>
      <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">{copy.ctaTitle}</h2>
      <p class="mt-4 text-sm leading-7 text-white/75">{copy.ctaText}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/booking" class="btn-primary bg-savanna-gold text-savanna-bark hover:bg-white">{shell.actions.bookNow}</a>
      <a href="/contact" class="btn-secondary border-white/30 bg-white/10 text-white hover:bg-white hover:text-savanna-bark">{shell.actions.talkToUs}</a>
    </div>
  </div>
</section>
