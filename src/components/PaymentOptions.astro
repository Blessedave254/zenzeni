---
const { amount = '', bookingReference = 'ZAS-DEMO-001' } = Astro.props;
---

<div class="grid gap-6 lg:grid-cols-2">
  <form class="rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60" method="post" action="/api/payments/mpesa">
    <p class="eyebrow">M-Pesa STK Push</p>
    <h2 class="mt-3 font-display text-2xl font-bold text-savanna-bark">Pay with M-Pesa</h2>
    <p class="mt-2 text-sm leading-6 text-stone-600">Prepared frontend flow for Safaricom Daraja STK Push integration.</p>
    <input type="hidden" name="bookingReference" value={bookingReference} />
    <label class="mt-5 grid gap-2 text-sm font-bold text-savanna-bark">
      M-Pesa phone number
      <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3 font-normal" name="phone" type="tel" placeholder="2547..." required />
    </label>
    <label class="mt-4 grid gap-2 text-sm font-bold text-savanna-bark">
      Amount
      <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3 font-normal" name="amount" type="number" value={amount} min="1" required />
    </label>
    <button class="btn-primary mt-5 w-full" type="submit">Request STK push</button>
  </form>

  <form class="rounded-2xl bg-white p-6 shadow-soft ring-1 ring-savanna-sand/60" method="post" action="/api/payments/card">
    <p class="eyebrow">Card payment</p>
    <h2 class="mt-3 font-display text-2xl font-bold text-savanna-bark">Pay by card</h2>
    <p class="mt-2 text-sm leading-6 text-stone-600">Placeholder card checkout UI ready for a provider such as Stripe, Pesapal, or Flutterwave.</p>
    <input type="hidden" name="bookingReference" value={bookingReference} />
    <label class="mt-5 grid gap-2 text-sm font-bold text-savanna-bark">
      Cardholder name
      <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3 font-normal" name="name" autocomplete="cc-name" required />
    </label>
    <label class="mt-4 grid gap-2 text-sm font-bold text-savanna-bark">
      Amount
      <input class="rounded-xl border border-savanna-sand bg-savanna-cream px-4 py-3 font-normal" name="amount" type="number" value={amount} min="1" required />
    </label>
    <button class="btn-primary mt-5 w-full" type="submit">Continue to card checkout</button>
  </form>
</div>
