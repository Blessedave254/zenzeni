---
import { site } from '@data/site';

const phone = site.whatsapp.replace(/\D/g, '');
const message = encodeURIComponent('Hello Zenzeni Africa Safaris, I would like help planning a trip.');
const href = `https://wa.me/${phone}?text=${message}`;
---

<a
  class="fixed bottom-6 right-4 z-50 grid h-12 w-12 place-items-center rounded-full bg-[#25D366] text-white shadow-[0_18px_35px_rgba(37,211,102,0.38)] ring-4 ring-white transition hover:-translate-y-1 hover:scale-105 hover:bg-[#1ebe5d] sm:right-6"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat with Zenzeni Africa Safaris on WhatsApp"
  title="Chat on WhatsApp"
>
  <svg class="h-7 w-7" viewBox="0 0 32 32" aria-hidden="true" fill="currentColor">
    <path d="M16.01 3.2A12.7 12.7 0 0 0 5.18 22.53L3.6 28.8l6.42-1.5A12.7 12.7 0 1 0 16.01 3.2Zm0 2.35a10.35 10.35 0 0 1 0 20.7c-1.82 0-3.6-.48-5.16-1.39l-.42-.24-3.48.82.85-3.38-.28-.45A10.35 10.35 0 0 1 16.01 5.55Zm-4.48 5.55c-.23 0-.6.08-.91.43-.31.35-1.2 1.17-1.2 2.86s1.23 3.32 1.4 3.55c.17.23 2.38 3.82 5.88 5.2 2.91 1.15 3.5.92 4.13.86.63-.06 2.03-.83 2.32-1.63.29-.8.29-1.48.2-1.63-.09-.15-.32-.23-.66-.4-.34-.17-2.03-1-2.35-1.12-.31-.12-.54-.17-.77.17-.23.34-.88 1.12-1.08 1.35-.2.23-.4.26-.74.09-.34-.17-1.44-.53-2.75-1.7-1.02-.91-1.7-2.03-1.9-2.37-.2-.34-.02-.52.15-.69.15-.15.34-.4.51-.6.17-.2.23-.34.34-.57.11-.23.06-.43-.03-.6-.09-.17-.77-1.86-1.06-2.55-.28-.67-.57-.58-.78-.59h-.7Z" />
  </svg>
</a>
